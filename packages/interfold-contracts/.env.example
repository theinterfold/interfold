RPC_URL=
ETHERSCAN_API_KEY=

# Used by the operator wallet that pays gas. Set exactly one.
PRIVATE_KEY=
MNEMONIC="test test test test test test test test test test test junk"

# Optional convenience fallback for sale/protocol scripts.
# Prefer passing --safe 0x... in runbooks so the address is visible in the command.
SAFE_ADDRESS=

# Optional: used by scripts/sale.ts and scripts/protocol.ts --action propose-safe.
# Hosted Safe Transaction Service may require an API key.
SAFE_API_KEY=
SAFE_TX_SERVICE_URL=

# Optional: used by scripts/sale.ts --action prepare to deploy a Predicate
# validation hook. You can also pass --predicate-registry and
# --predicate-policy-id explicitly.
PREDICATE_REGISTRY=
PREDICATE_POLICY_ID=

# Optional: used by packages/interfold-sale dev proxy/backend for gated bids.
# Do not expose this in browser-visible client env.
PREDICATE_API_KEY=

# Optional protocol deployment address overrides.
# Prefer explicit config files for release, but these are supported by scripts/protocol.
FEE_TOKEN=
PROTOCOL_TREASURY=
SLASHED_FUNDS_TREASURY=
